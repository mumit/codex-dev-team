{
  "name": "codex-dev-team",
  "version": "0.2.0",
  "private": true,
  "description": "A Codex-native software development team framework with gates, skills, audits, and review workflows",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test tests/*.test.js",
    "lint": "node scripts/lint-syntax.js",
    "gate:check": "node scripts/gate-validator.js",
    "status": "node scripts/codex-team.js status",
    "roadmap": "node scripts/codex-team.js roadmap",
    "validate": "node scripts/codex-team.js validate",
    "doctor": "node scripts/codex-team.js doctor",
    "reset": "node scripts/codex-team.js reset",
    "review:derive": "node scripts/approval-derivation.js",
    "security:check": "node scripts/security-heuristic.js",
    "runbook:check": "node scripts/runbook-check.js"
  }
}
